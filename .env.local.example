# Site URL (update when you have a custom domain)
NEXT_PUBLIC_SITE_URL=https://marketnotes.vercel.app

# Giscus Comments — get values from https://giscus.app
# After enabling GitHub Discussions on your repo and connecting it to Giscus:
NEXT_PUBLIC_GISCUS_REPO=your-github-username/market-notes
NEXT_PUBLIC_GISCUS_REPO_ID=R_your_repo_id
NEXT_PUBLIC_GISCUS_CATEGORY=General
NEXT_PUBLIC_GISCUS_CATEGORY_ID=DIC_your_category_id

# Beehiiv Newsletter — get your publication ID from Beehiiv dashboard
# Settings > Publication > Publication ID (starts with "pub_")
NEXT_PUBLIC_BEEHIIV_EMBED_ID=pub_your_beehiiv_publication_id
